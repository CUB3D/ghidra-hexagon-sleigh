<patternlist>
    <!-- NOTE: These are matching on raw bytes, not on 32bit LE instructions, so
    the bytes are endian-swapped here -->

    <patternpairs totalbits="26" postbits="24">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data> .......0 ........ ........ 0101101. ........ 11000...
                100..... 10100000 </data> <!-- {CALL XXX; allocframe(Rx,imm):raw} -->
            <codeboundary />
            <possiblefuncstart />
        </postpatterns>
    </patternpairs>

    <patternpairs totalbits="12" postbits="10">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data> .......0 11...... ........ 0101100. </data> <!-- { JUMP XXX } -->
            <codeboundary />
            <possiblefuncstart thunk="true" />
        </postpatterns>
    </patternpairs>

    <patternpairs totalbits="16" postbits="14">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data>.......0 11...... ........ 0101100. ........ ........ ........
                0000....</data> <!-- { immext(N) JUMP XXX } -->
            <codeboundary />
            <possiblefuncstart thunk="true" />
        </postpatterns>
    </patternpairs>

    <patternpairs totalbits="18" postbits="16">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data>........ 11000... 100..... 10100000</data> <!-- { allocframe(N)
            } -->
            <codeboundary />
            <possiblefuncstart />
        </postpatterns>
    </patternpairs>
    <patternpairs totalbits="20" postbits="18">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data>........ 01...... ........ ........ ........ 11000... 100.....
                10100000</data> <!-- { <any> allocframe(N) } -->
            <data>........ 10...... ........ ........ ........ 11000... 100.....
                10100000</data> <!-- { <any> allocframe(N) } -->
            <codeboundary />
            <possiblefuncstart />
        </postpatterns>
    </patternpairs>

    <!-- Duplex allocframe:
  60 3c 00 79   0b 01111001000000000011110001100000
  10 1c 4f eb   0b 11101011010011110001110000010000
  10 1c f4 eb   0b 11101011111101000001110000010000
  20 1c f4 eb   0b 11101011111101000001110000100000
  40 3c 10 79   0b 01111001000100000011110001000000
  80 3c 00 79   0b 01111001000000000011110010000000
                   .11.10.1........00.11100....0000
  -->
    <patternpairs totalbits="18" postbits="16">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data>.11.10.1 ........ 00.11100 ....0000 </data> <!-- {{ <any>;
            allocframe(N) }} -->
            <codeboundary />
            <possiblefuncstart />
        </postpatterns>
    </patternpairs>
    <patternpairs totalbits="20" postbits="18">
        <prepatterns>
            <!-- Any sub-instruction with end of packet marker -->
            <data> ........11...................... </data>
        </prepatterns>
        <postpatterns>
            <data>.11.10.1 ........ 00.11100 ....0000 ........ 10...... ........
                ........ </data> <!-- { <any> {{ <any>; allocframe(N) }} } -->
            <data>.11.10.1 ........ 00.11100 ....0000 ........ 01...... ........
                ........ </data> <!-- { <any> {{ <any>; allocframe(N) }} } -->
            <codeboundary />
            <possiblefuncstart />
        </postpatterns>
    </patternpairs>

    <pattern>
        <!-- { nop; jumpr lr; memd(fp-0x10)=r19r18; memd(fp-0x8)=r17r16; } -->
        <data>0x00 0x40 0x00 0x7f 0x00 0x40 0x9f 0x52 0xfe 0x72 0xde 0xa7 0xff
            0xf0 0xde 0xa7</data>
        <codeboundary />
        <funcstart label="__backup_r16_to_r19" />
    </pattern>

    <pattern>
        <!-- { jumpr lr; memd(fp-0x8)=r17r16; } -->
        <data>0x00 0x40 0x9f 0x52 0xff 0xf0 0xde 0xa7</data>
        <codeboundary />
        <funcstart label="__backup_r16_to_r17" />
    </pattern>


    <pattern>
        <data>0xf0 0x7f 0xde 0x97 0x1e 0xc0 0x1e 0x96</data>
        <codeboundary />
        <funcstart noreturn="true"
            label="__restore_r16_through_r17_and_deallocframe" />
    </pattern>

    <pattern>
        <data>0x00 0x40 0x00 0x7f 0x00 0x40 0x9f 0x52 0xf0 0x7f 0xde 0x97 0x1e
            0xc0 0x1e 0x90</data>
        <codeboundary />
        <funcstart noreturn="true"
            label="__restore_r16_through_r17_and_deallocframe_before_tailcall" />
    </pattern>

    <!-- TODO: 16 to 19 -->

    <!-- r16 to r21 -->
    <!-- TODO: no allowed yet, can only define a func start in post patterns
  <patternpairs totalbits="128" postbits="64">
    <prepatterns>
        <data>0xb4 0x7f 0xde 0x97 0xd2 0xff 0xde 0x97</data>
        <codeboundary/>
        <funcstart noreturn="true" label="__restore_r16_through_r21_and_deallocframe"/>
    </prepatterns>
    <postpatterns>
        <data>0xf0 0x7f 0xde 0x97 0x1e 0xc0 0x1e 0x96 </data>
    </postpatterns>
  </patternpairs>

  TODO: tailcall
  -->

    <!-- TODO: r16 to r23 -->
    <pattern>
        <data>0x00 0x40 0x00 0x7f 0x96 0x7f 0xde 0x97 0xb4 0xff 0xde 0x97</data>
        <codeboundary />
        <funcstart noreturn="true"
            label="__restore_r16_through_r23_and_deallocframe_before_tailcall" />
    </pattern>
    <!-- TODO: rest -->


  <!-- Borrowed from Ghidra Hexagon module -->
  <patternpairs>
  
    <prepatterns>
    
      <data>01000000 00111111 ........ 0.0..... </data> <!-- packed EE dealloc_return -->
      <data>01000000 00011111 ........ 001..... </data> <!-- packed EE dealloc_return -->
      
      <data>11000000 00111111 ........ 0.0..... </data> <!-- packed EE jumpr LR -->
      <data>11000000 00011111 ........ 001..... </data> <!-- packed EE jumpr LR -->

      <data>00011110 11000000 00011110 10010110 </data> <!-- PP dealloc_return, last -->
      <data>00011110 01000000 00011110 10010110 ........ 11...... ........ ........ </data> <!-- PP dealloc_return, 2nd to last -->
      <data>00011110 01000000 00011110 10010110 ........ 00...... ........ ........ </data> <!-- PP dealloc_return, 2nd to last -->
      <data>00011110 01000000 00011110 10010110 ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP dealloc_return, 3rd to last -->
      <data>00011110 01000000 00011110 10010110 ........ 01...... ........ ........ ........ 00...... ........ ........ </data> <!-- PP dealloc_return, 3rd to last -->
      <data>00011110 01000000 00011110 10010110 ........ 01...... ........ ........ ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP dealloc_return 4th to last -->
      
      <data>.......0 11...... ........ 0101100. </data> <!-- PP jump, last -->
      <data>.......0 01...... ........ 0101100. ........ 11...... ........ ........ </data> <!-- PP jump, 2nd to last -->
      <data>.......0 01...... ........ 0101100. ........ 00...... ........ ........ </data> <!-- PP jump, 2nd to last -->
      <data>.......0 01...... ........ 0101100. ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP jump, 3rd to last -->
      <data>.......0 01...... ........ 0101100. ........ 01...... ........ ........ ........ 00...... ........ ........ </data> <!-- PP jump, 3rd to last -->
      <data>.......0 01...... ........ 0101100. ........ 01...... ........ ........ ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP jump 4th to last -->
      
      <data>00000000 01000000 100..... 01010010 </data> <!-- PP jumpr, last -->
      <data>00000000 01000000 100..... 01010010 ........ 11...... ........ ........ </data> <!-- PP jumpr, 2nd to last -->
      <data>00000000 01000000 100..... 01010010 ........ 00...... ........ ........ </data> <!-- PP jumpr, 2nd to last -->
      <data>00000000 01000000 100..... 01010010 ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP jumpr, 3rd to last -->
      <data>00000000 01000000 100..... 01010010 ........ 01...... ........ ........ ........ 00...... ........ ........ </data> <!-- PP jumpr, 3rd to last -->
      <data>00000000 01000000 100..... 01010010 ........ 01...... ........ ........ ........ 01...... ........ ........ ........ 11...... ........ ........ </data> <!-- PP jumpr 4th to last -->
      
    </prepatterns>
    
    <postpatterns>
    
      <!-- First Instruction in Packet -->
      <data>........ .1000... 10011101 10100000 </data> <!-- allocframe (v2,10) - 1st in packet -->
      <data>....0000 0011110. ........ 011..... </data> <!-- allocframe (v4,right,6,7) - 1 of 1 in packet -->
      <data>....0000 0011110. ........ 101..... </data> <!-- allocframe (v4,right,10,11) - 1 of 1 in packet -->
      <data>....0000 00.1110. ........ 110..... </data> <!-- allocframe (v4,right,12,13) - 1 of 1 in packet -->
      <data>....0000 0001110. ........ 111..... </data> <!-- allocframe (v4,right,14,15) - 1 of 1 in packet -->
      
      <!-- Second Instruction in Packet -->
      <data>........ 01...... ........ ........ ........ .1000... 10011101 10100000 </data> <!-- allocframe (v2,10) - 2nd in packet -->
      <data>........ 01...... ........ ........ ....0000 0011110. ........ 011..... </data> <!-- allocframe (v4,right,6,7) - 2 of 2 in packet -->
      <data>........ 01...... ........ ........ ....0000 0011110. ........ 101..... </data> <!-- allocframe (v4,right,10,11) - 2 of 2 in packet -->
      <data>........ 01...... ........ ........ ....0000 00.1110. ........ 110..... </data> <!-- allocframe (v4,right,12,13) - 2 of 2 in packet -->
      <data>........ 01...... ........ ........ ....0000 0001110. ........ 111..... </data> <!-- allocframe (v4,right,14,15) - 2 of 2 in packet -->
      
      <!-- Third Instruction in Packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ .1000... 10011101 10100000 </data> <!-- allocframe (v2,10) - 3rd in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0011110. ........ 011..... </data> <!-- allocframe (v4,right,6,7) - 3 of 3 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0011110. ........ 101..... </data> <!-- allocframe (v4,right,10,11) - 3 of 3 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 00.1110. ........ 110..... </data> <!-- allocframe (v4,right,12,13) - 3 of 3 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0001110. ........ 111..... </data> <!-- allocframe (v4,right,14,15) - 3 of 3 in packet -->
      
      <!-- Fourth Instruction in Packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ 01...... ........ ........ ........ 11000... 10011101 10100000 </data> <!-- allocframe (v2,10) - 4th in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0011110. ........ 011..... </data> <!-- allocframe (v4,right,6,7) - 4 of 4 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0011110. ........ 101..... </data> <!-- allocframe (v4,right,10,11) - 4 of 4 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 00.1110. ........ 110..... </data> <!-- allocframe (v4,right,12,13) - 4 of 4 in packet -->
      <data>........ 01...... ........ ........ ........ 01...... ........ ........ ........ 01...... ........ ........ ....0000 0001110. ........ 111..... </data> <!-- allocframe (v4,right,14,15) - 4 of 4 in packet -->
      
      <funcstart validcode="8" />
      
    </postpatterns>
    
  </patternpairs>

</patternlist>
